  m_Script: {fileID: 11500000, guid: f8649c6e61b6f605a90e19251292c48e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NormalDialogScript
  dialog:
  - ...
  - 'Boss: Welcome on your first day on the job!'
  - 'Boss: Your task is very simple. Redact the words indicated on the list by clicking
    them!'
  - 'Boss: Put stickers on documents before sending it off for a small bonus!'
  - 'Boss: And be careful to not wrongfully redact words or leave words unredacted.
    That will come out of your paycheck!'
  - 'Boss: Also, keep an eye out for World Events, they might affect how things work
    around here!'
  - 'Boss: Alrighty, now go ahead and... '
  - REDACT THOSE FILES!
  voiceSound: {fileID: 127490205613484029}
  buttonSound: {fileID: 7562131689102787538}
  encounterMafia: 0
