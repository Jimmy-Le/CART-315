  m_Script: {fileID: 11500000, guid: f8649c6e61b6f605a90e19251292c48e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NormalDialogScript
  dialog:
  - 'Boss: Welcome on your first day on the job!'
  - 'Boss: Your task is very simple. Redact the words indicated on the list by clicking
    them!'
  - 'Boss: If you ever have to redact pictures, drag a sticker on em and call it
    a day! (Not Implemented Yet)'
  - 'Boss: Careful to not wrongfully redact words or leave words unredacted, that
    will come out of your paycheck!'
  - 'Boss: Also, keep an eye out for World Events, they might affect how things work
    around here!'
  - 'Boss: Alrighty, now go ahead and Redact Those Files!'
